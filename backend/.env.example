# Google Places API - Get from https://console.cloud.google.com
GOOGLE_API_KEY=

# Yelp Fusion API (optional) - Free tier: 500 calls/day
YELP_API_KEY=

# Hunter.io API (optional) - Free tier: 25 requests/month
HUNTER_API_KEY=

# SMTP / Email (Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# Google Sheets Export (Option B - file path, recommended)
GOOGLE_SHEETS_CREDENTIALS_FILE=service-account.json
# Option A: GOOGLE_SHEETS_CREDENTIALS={"type":"service_account",...}

# Google Sheet ID from the URL: docs.google.com/spreadsheets/d/<THIS_IS_THE_ID>/edit
GOOGLE_SHEETS_ID=
