# Google Places API - Get from https://console.cloud.google.com
GOOGLE_API_KEY=

# Yelp Fusion API (optional) - Free tier: 500 calls/day
YELP_API_KEY=

# Hunter.io API (optional) - Free tier: 25 requests/month
HUNTER_API_KEY=

# SMTP / Email (Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# Google Sheets Export (Option B - file path, recommended)
GOOGLE_SHEETS_CREDENTIALS_FILE=service-account.json
# Option A: GOOGLE_SHEETS_CREDENTIALS={"type":"service_account",...}

# Google Sheet ID from the URL: docs.google.com/spreadsheets/d/<THIS_IS_THE_ID>/edit
GOOGLE_SHEETS_ID=

# Anthropic Claude API (optional but recommended) - AI-personalized drafts + audits
# Get a key at https://platform.claude.com -> Settings -> API Keys
ANTHROPIC_API_KEY=
# AI_MODEL=claude-opus-4-8

# Local OLLAMA LLM - for deep AI analysis of leads
# Default: http://localhost:11434 with model llama3.2
# Make sure OLLAMA is running: ollama serve
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Your identity - seeds the Settings page (editable in the UI afterwards)
MY_NAME=
MY_COMPANY=
MY_WEBSITE=
CALENDLY_LINK=
