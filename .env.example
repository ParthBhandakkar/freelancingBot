# Copy this file to `.env` and fill values before running the project.
# This file is safe to commit.

# LinkedIn credentials
LINKEDIN_EMAIL=your_linkedin_email
LINKEDIN_PASSWORD=your_linkedin_password

# LLM selection: kimi, ollama, openai
LLM_PROVIDER=ollama

# Kimi K2.5 (optional if using kimi)
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.5

# Ollama (optional if using ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=kimi-k2.5:cloud

# OpenAI (optional if using openai)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Browser behavior
HEADLESS=false
SLOW_MO=50
BROWSER_TIMEOUT=60000

# Timing
SEARCH_DELAY_MIN=3.0
SEARCH_DELAY_MAX=7.0
OUTREACH_DELAY_MIN=2.0
OUTREACH_DELAY_MAX=6.0

# Campaign control
MAX_DISCOVERY_RESULTS=120
MAX_OUTREACH_PER_RUN=20
MIN_FIT_SCORE=55
SCROLL_ROUNDS_PER_QUERY=7
DISCOVER_PLATFORMS=linkedin,linkedin_posts,linkedin_posts_native,upwork,upwork_rss,clutch,yc
MAX_WEB_RESULTS_PER_QUERY=4

# Portfolio and persona
PORTFOLIO_URL=https://portfolio-bhandakkarparth.netlify.app/
FREELANCER_NAME=Your Name
FREELANCER_ROLE=Your Role
FREELANCER_SUMMARY=Your short professional summary.
FREELANCER_FOCUS=Your service focus

# Search and filtering
SEARCH_QUERIES=founder ai automation startup, cto saas backend platform, head of product analytics dashboard
BUYER_INTENT_SEARCH_QUERIES="looking for" freelancer backend automation, "need help with" ai automation project
LINKEDIN_POST_QUERIES=looking for developer, need help with automation, hiring freelancer backend, who can build
UPWORK_RSS_QUERIES=backend developer, AI automation, full stack developer, python developer api, saas dashboard
ROLE_KEYWORDS=founder,co-founder,ceo,cto,vp engineering,head of engineering,head of product,engineering manager,operations head,technical founder
INDUSTRY_KEYWORDS=ai,artificial intelligence,machine learning,automation,backend,software,saas,tech startup,ecommerce,analytics,dashboard
LEAD_BLACKLIST_KEYWORDS=recruiter,hiring manager,job board,training,agency,placement,staffing,consultant,freelancer,coach,open to work,job seeker

# Outreach settings
OUTREACH_SEND_MESSAGE_IF_POSSIBLE=true
SOFT_PITCH_ENABLED=true
OUTREACH_MESSAGE_TEMPLATE=Hi {first_name}, I noticed your work in {company}. I help teams build practical automation and AI/ML product features with strong full-stack execution. If you'd like, I can share a quick plan using my portfolio at {portfolio_url}.
OUTREACH_CONNECTION_NOTE_TEMPLATE=Hi {first_name}, fellow builder in the AI/automation space. Would love to connect!
OUTREACH_PITCH_MESSAGE_TEMPLATE=Hi {first_name}, thanks for connecting! I noticed your work at {company}. I help teams ship backend-heavy products, AI automation, and analytics dashboards. Would love to share a quick plan if you have any upcoming projects — here's my portfolio: {portfolio_url}
OUTREACH_SIGNATURE=Best, {freelancer_name}

# Follow-up nurturing
FOLLOWUP_1_DELAY_DAYS=3
FOLLOWUP_2_DELAY_DAYS=7
FOLLOWUP_1_TEMPLATE=Hey {first_name}, just bumping this to the top of your inbox. Let me know if you have any bandwidth to chat this week about your {company} projects.
FOLLOWUP_2_TEMPLATE=Hi {first_name}, last follow-up from me! If you ever need help with backend engineering, AI automation, or dashboard builds, I'm a message away. Portfolio: {portfolio_url}

# Email outreach (optional - requires Hunter.io and SMTP credentials)
HUNTER_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=
EMAIL_DAILY_LIMIT=30
EMAIL_SUBJECT_TEMPLATE=Quick question about {company}
EMAIL_BODY_TEMPLATE=Hi {first_name}, I came across {company} and was impressed by what you're building. I specialize in backend engineering, AI automation, and analytics dashboards. Would you be open to a quick chat? Portfolio: {portfolio_url}

# Storage
LEAD_STORE_FILE=freelance_leads.csv
GOOGLE_SHEET_ID=
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_OUTREACH_SHEET_NAME=Outreach
GOOGLE_OUTREACH_ENABLED=true
